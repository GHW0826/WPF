<Page x:Class="Example3.Modules.HomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:prism="http://prismlibrary.com/"
      prism:ViewModelLocator.AutoWireViewModel="True"
      xmlns:local="clr-namespace:Example3.Modules"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomeView">
    <StackPanel Margin="20" HorizontalAlignment="Center">
        <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" Margin="0,0,0,12"/>
        <Button Content="Change Message"
                Command="{Binding ChangeMessageCommand}" Width="160"/>
    </StackPanel>
</Page>
