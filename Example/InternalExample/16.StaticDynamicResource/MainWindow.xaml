<Window x:Class="StaticDynamicResource.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StaticDynamicResource"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20" x:Name="LayoutRoot">
        <TextBlock Text="StaticResource 적용"
                   Background="{StaticResource StaticBrush}"
                   Padding="10" Margin="0 10"/>

        <TextBlock Text="DynamicResource 적용"
                   Background="{DynamicResource DynamicBrush}"
                   Padding="10" Margin="0 10"/>

        <Button Content="색상 변경 (LightSalmon)"
                Click="OnChangeBrushClick"
                Padding="5"/>
    </StackPanel>
</Window>
